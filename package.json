{
  "name": "hilum-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Hilum UI — design system and component platform monorepo",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hilum-labs/hilum-ui.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:packages": "turbo build --filter=./packages/*",
    "release:version": "changeset version",
    "release:publish": "turbo build --filter=./packages/* && changeset publish",
    "changeset": "changeset",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "catalog": "pnpm --filter @hilum/catalog dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^20.9.0",
    "tsup": "^8.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
