{
  "name": "@hilum/designer",
  "version": "3.6.4",
  "private": false,
  "description": "Engine-agnostic canvas-editor chrome — DesignerShell, Toolbar, Panel, Pane + generic useHistory and useKeybindings hooks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hilum-labs/hilum-ui.git",
    "directory": "packages/designer"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "//": "Tests for this package live in src/**/*.test.ts and run from the root via `pnpm test`.",
  "peerDependencies": {
    "@hilum/ui": "^3.3.4",
    "lucide-react": ">=0.511.0 <1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@hilum/ui": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.542.0",
    "tailwindcss": "^4.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
