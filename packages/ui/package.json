{
  "name": "@hilum/ui",
  "version": "3.2.7",
  "private": false,
  "description": "Hilum UI — design system primitives (Button, Input, Dialog, Combobox, …) + tokens + fonts + icons",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hilum-labs/hilum-ui.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./icons": {
      "import": "./dist/icons.js",
      "types": "./dist/icons.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens.js",
      "types": "./dist/tokens.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./fonts.css": "./dist/fonts.css",
    "./fonts/*": "./dist/fonts/*",
    "./create-theme": {
      "import": "./dist/create-theme.js",
      "types": "./dist/create-theme.d.ts"
    }
  },
  "files": [
    "dist",
    "src/components/*.tsx",
    "src/icons.ts",
    "src/index.ts",
    "src/lib/*.ts",
    "src/tokens/*.ts",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/build-tokens.mjs && node ./scripts/build-fonts.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "lucide-react": ">=0.511.0 <1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-context": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "radix-ui": "^1.1.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/gabarito": "^5.2.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.542.0",
    "tailwindcss": "^4.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
