{
  "name": "@hilum/blocks",
  "version": "3.2.2",
  "private": false,
  "description": "Hilum UI CLI — add marketing blocks to your project",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hilum-labs/hilum-ui.git",
    "directory": "packages/blocks"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
