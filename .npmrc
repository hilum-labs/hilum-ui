# Use a hoisted node_modules layout (npm-compatible) so TypeScript can name
# inferred types from transitively-bundled packages (e.g. vaul → @radix-ui/react-dialog).
# Strict pnpm layout breaks dts emission with TS2742 on Drawer/Menubar.
node-linker=hoisted

# Strict peer dep checking; warn on missing.
strict-peer-dependencies=false
auto-install-peers=true
